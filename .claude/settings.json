{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": ["Read(~/.zshrc)", "Read(**/.env.example)"],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)"],
    "defaultMode": "default"
  },
  "alwaysThinkingEnabled": false,
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  }
}
