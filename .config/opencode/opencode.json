{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "inspection-db": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--dsn",
        "{env:INSPECTION_DB_DSN}"
      ],
      "enabled": false
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow",
      "~/Library/Application Support/rtk/*": "allow"
    }
  },
  "plugin": ["opencode-glm-quota", "github:nisibz/opencode-plugin-zhipu-retry"]
}
